[sub_resource type="GDScript" id="GDScript_b8a5l"]
resource_name = "HealthDisplay"
script/source = "extends Node

@export var playerMaterial : Material

var ourMaterial : Material

# Called when the node enters the scene tree for the first time.
func _ready() -> void:
	ourMaterial = playerMaterial.duplicate()
	$\"../Polygon\".set(\"material\",ourMaterial)


# Called every frame. 'delta' is the elapsed time since the previous frame.
func _process(_delta: float) -> void:
	ourMaterial.set(\"shader_parameter/Progress\",float($\"..\".hpLeft)/float($\"..\".maxHP))
"

