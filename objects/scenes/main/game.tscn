[sub_resource type="GDScript" id="GDScript_eupl3"]
script/source = "extends Control

# --|| VARIABLES ||--

@export_group(\"Nodes\",\"node_\")
## The Label that will display messages.
@export var node_chatLabel : Label
## The LineEdit that will be used to write messages.
@export var node_chatInput : LineEdit

# --|| MAIN FUNCTIONS ||--

# Called when the node enters the scene tree for the first time.
func _ready() -> void:
	LobbyManager.chatMessageReceived.connect(chatMessageReceived)

# --|| LOGIC FUNCTIONS ||--

func chatMessageReceived(_senderId : int, senderName : String, message : String) -> void:
	if not node_chatLabel: return
	node_chatLabel.text += \"[%s]: %s\\n\" % [senderName,message]

func chatMessageSubmitted(message : String) -> void:
	node_chatInput.text = \"\"
	node_chatInput.release_focus()
	LobbyManager.sendLobbyMessage(message)
"

